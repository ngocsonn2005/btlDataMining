# Data files - CHỈ BỎ QUA FILE LỚN (train.csv, test.csv)
data/raw/train.csv
data/raw/test.csv
# Giữ lại các file khác trong data/raw (nếu có)
!data/raw/.gitkeep

# Processed data - ĐẨY TẤT CẢ (bỏ comment để giữ lại)
# data/processed/*
!data/processed/.gitkeep

# ==========================================
# MODEL FILES - CHO PHÉP TẤT CẢ FILE .pkl HIỆN CÓ
# ==========================================
# Bỏ qua tất cả file trong outputs/models
outputs/models/*
# NHƯNG cho phép các file model .pkl (bao gồm best_logistic_regression.pkl, kmeans_model.pkl, scaler.pkl, tfidf_vectorizer.pkl)
!outputs/models/*.pkl
# Giữ file .gitkeep để maintain thư mục (nếu cần)
!outputs/models/.gitkeep
